{
    "tasks": [
        {
            "type": "cppbuild",
            "label": "Build Backend CLI",
            "command": "g++.exe",
            "args": [
                "-fdiagnostics-color=always",
                "-g",
                "-std=c++17",
                "-Ibackend/include",
                "${workspaceFolder}\\backend\\src\\main.cpp",
                "${workspaceFolder}\\backend\\src\\event.cpp",
                "${workspaceFolder}\\backend\\src\\calendar.cpp",
                "${workspaceFolder}\\backend\\src\\file_manager.cpp",
                "${workspaceFolder}\\backend\\src\\ds_utility.cpp",
                "${workspaceFolder}\\backend\\src\\linked_list.cpp",
                "${workspaceFolder}\\backend\\src\\bst.cpp",
                "${workspaceFolder}\\backend\\src\\min_heap.cpp",
                "${workspaceFolder}\\backend\\src\\hash_table.cpp",
                "-o",
                "${workspaceFolder}\\calendar_cli.exe",
                "-Wl,-subsystem,console"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": ["$gcc"],
            "group": "build"
        },
        {
            "type": "cppbuild",
            "label": "Build Backend Server",
            "command": "g++.exe",
            "args": [
                "-fdiagnostics-color=always",
                "-g",
                "-std=c++17",
                "-Ibackend/include",
                "${workspaceFolder}\\backend\\src\\server.cpp",
                "${workspaceFolder}\\backend\\src\\event.cpp",
                "${workspaceFolder}\\backend\\src\\calendar.cpp",
                "${workspaceFolder}\\backend\\src\\file_manager.cpp",
                "${workspaceFolder}\\backend\\src\\ds_utility.cpp",
                "${workspaceFolder}\\backend\\src\\linked_list.cpp",
                "${workspaceFolder}\\backend\\src\\bst.cpp",
                "${workspaceFolder}\\backend\\src\\min_heap.cpp",
                "${workspaceFolder}\\backend\\src\\hash_table.cpp",
                "-o",
                "${workspaceFolder}\\calendar_server.exe",
                "-Wl,-subsystem,console",
                "-lws2_32"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": ["$gcc"],
            "group": "build"
        },
        {
            "type": "npm",
            "label": "Build Frontend",
            "script": "build",
            "path": "frontend",
            "group": "build",
            "problemMatcher": []
        },
        {
            "type": "npm",
            "label": "Dev Frontend",
            "script": "dev",
            "path": "frontend",
            "group": "build",
            "problemMatcher": []
        }
    ],
    "version": "2.0.0"
}
